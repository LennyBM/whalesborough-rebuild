# ===========================================
# Whalesborough Farm Resort & Spa — env.example
# Copy to .env.local for local development.
# ===========================================

# --- Application ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Supabase Postgres, eu-west-2 London) ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# --- Supabase ---
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple OAuth
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Sanity CMS ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=hello@whalesborough.co.uk

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Inngest (background jobs) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Sentry (error monitoring) ---
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Cloudflare Images ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_API_TOKEN=
NEXT_PUBLIC_CLOUDFLARE_IMAGES_HASH=

# --- Analytics ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=whalesborough.co.uk

# Skip env validation in CI/build when secrets unavailable.
# SKIP_ENV_VALIDATION=1
