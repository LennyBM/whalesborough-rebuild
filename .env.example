# ===========================================
# Whalesborough Farm Resort & Spa — env.example
# Copy to .env.local for local development.
# ===========================================

# --- Application ---
NODE_ENV=development
# Base URL of the app (used for absolute links, OG images, callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Supabase Postgres, eu-west-2 London) ---
# Pooled connection string (for Prisma/Drizzle queries)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Direct connection (for migrations, bypasses PgBouncer)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# --- Supabase ---
# Server-side Supabase URL (same as public, used by service role client)
SUPABASE_URL=https://[REF].supabase.co
# Service role key — FULL access, server-only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
# Client-side Supabase config (safe to expose, RLS enforced)
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
# Required: signs session JWTs
AUTH_SECRET=
# Override in production (defaults to NEXT_PUBLIC_APP_URL)
AUTH_URL=http://localhost:3000

# Google OAuth (Console > Credentials > OAuth 2.0 Client)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple OAuth (Developer Portal > Certificates, Identifiers & Profiles)
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# --- Stripe ---
# Secret key (server-only, starts sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret (starts whsec_)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Publishable key (safe for client, starts pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Sanity CMS ---
# Project ID from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production
# API token for server-side mutations (Editor or Deploy role)
SANITY_API_TOKEN=

# --- Resend (transactional email) ---
# API key from resend.com/api-keys
RESEND_API_KEY=re_xxx
# Verified sender address (must match Resend domain)
RESEND_FROM_EMAIL=hello@whalesborough.co.uk

# --- Twilio (SMS notifications) ---
# Account SID from twilio.com/console
TWILIO_ACCOUNT_SID=
# Auth token from twilio.com/console
TWILIO_AUTH_TOKEN=
# Purchased phone number (E.164 format)
TWILIO_FROM_NUMBER=

# --- Inngest (background jobs & scheduled tasks) ---
# Event key for sending events
INNGEST_EVENT_KEY=
# Signing key for webhook verification
INNGEST_SIGNING_KEY=

# --- Sentry (error monitoring) ---
# DSN from sentry.io project settings
SENTRY_DSN=
# Organization slug
SENTRY_ORG=
# Project slug
SENTRY_PROJECT=
# Auth token for source map uploads (CI only)
SENTRY_AUTH_TOKEN=

# --- Cloudflare Images ---
# Account ID from Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=
# API token with Images:Edit permission
CLOUDFLARE_IMAGES_API_TOKEN=
# Account hash for public image delivery URLs
NEXT_PUBLIC_CLOUDFLARE_IMAGES_HASH=

# --- Analytics ---
# Plausible domain (self-hosted or cloud)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=whalesborough.co.uk

# --- Build ---
# Skip env validation in CI/build when secrets unavailable.
# SKIP_ENV_VALIDATION=1
